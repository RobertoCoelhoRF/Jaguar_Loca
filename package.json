    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "pg": "^8.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "vite": "^7.1.12"
