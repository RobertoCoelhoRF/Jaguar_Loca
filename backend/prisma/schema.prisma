generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  cpf       String   @unique
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}   

model Veiculo {
  id        Int      @id @default(autoincrement())
  nome      String
  cadeiras  Int
  acessorios String?
  image     String?
  createdAt DateTime @default(now())
}
