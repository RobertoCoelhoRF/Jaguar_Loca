generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CambioTipo {
  MANUAL
  AUTOMATICO
}

enum PortaMalasTamanho {
  PEQUENO
  MEDIO
  GRANDE
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String
  cpf       String    @unique
  email     String    @unique
  senha     String
  createdAt DateTime  @default(now())
  reservas  Reserva[]
}

model Veiculo {
  id           Int       @id @default(autoincrement())
  nome         String
  cadeiras     Int
  vidroEletrico    Boolean            @default(false)
  arCondicionado   Boolean            @default(false)
  cambio           CambioTipo         @default(MANUAL)
  travaEletrica    Boolean            @default(false)
  direcaoHidraulica Boolean           @default(false)
  portaMalas       PortaMalasTamanho  @default(MEDIO)
  foto         String?
  precoDiaria  Float
  reservado    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  reservas     Reserva[]
}

model Reserva {
  id           Int      @id @default(autoincrement())
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId    Int
  veiculo      Veiculo  @relation(fields: [veiculoId], references: [id])
  veiculoId    Int
  dataRetirada DateTime
  horaRetirada String
  dataDevolucao DateTime @default(now())
  valorTotal   Float    @default(0)
  observacoes  String?
  createdAt    DateTime @default(now())
}
